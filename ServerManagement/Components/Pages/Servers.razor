@page "/servers"
@using ServerManagement.Components.Controls

@inject IDialogService DialogService
@inject ServerClient ServerClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<div class="d-flex flex-column flex-grow-1 gap-4">

    <PageTitle>Servers</PageTitle>

    <MudTable Items="@_servers" Dense="false" Hover="true" Bordered="true" Striped="true" Filter="new Func<ServerSummary, bool>(FilterTable)" @bind-SelectedItem="_selectedServer">
        <ToolBarContent>
            <MudText Typo="Typo.h6">All Servers</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Host Name</MudTh>
            <MudTh>Primary IP</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Online">@context.IsOnline</MudTd>
            <MudTd DataLabel="Status">@context.Status</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Host Name">@context.HostName</MudTd>
            <MudTd DataLabel="Primary IP">@context.PrimaryIp</MudTd>
            <MudTd>
                <MudLink Href="@($"/servers/edit/{context.Id.ToString()}")" Typo="Typo.subtitle1"
                         StartIcon="@Icons.Material.Filled.Edit"></MudLink>
                <MudIconButton @onclick="() => OpenDeleteConfirmDialogAsync(context.Id)"
                               Icon="@Icons.Material.Filled.Delete" Size="Size.Small" aria-label="delete"
                               Color="Color.Error"></MudIconButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

    <div class="d-flex flex-row-reverse">
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" @onclick="NavigateToCreateServer" />
    </div>
</div>

@code {
    private string _searchString = "";
    private ServerSummary? _selectedServer;

    private IEnumerable<ServerSummary> _servers = new List<ServerSummary>();

    protected override async Task OnInitializedAsync()
    {
        _servers = await ServerClient.GetServersList();
    }

    private void NavigateToCreateServer()
    {
        NavigationManager.NavigateTo("/servers/new");
    }

    private bool FilterTable(ServerSummary element) => SearchServers(element, _searchString);

    private bool SearchServers(ServerSummary element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.HostName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.Name} {element.HostName} {element.PrimaryIp}".Contains(searchString))
            return true;
        return false;
    }

    private async Task OpenDeleteConfirmDialogAsync(Guid serverId)
    {
        var parameters = new DialogParameters<ServerDialog>
        {
            { x => x.ContentText, "Are you sure you want to delete this server? This action cannot be undone." },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error },
            { x => x.EntityId, serverId.ToString() },
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await DialogService.ShowAsync<ServerDialog>("Confirm Delete", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: true }) return;
        Console.WriteLine($"Server {serverId} is being deleted....");
        var response = await ServerClient.DeleteServer(serverId);

        if (response?.Status.ToLower() == "success")
        {
            Snackbar.Add("Server has been deleted successfully.", Severity.Success);
            await ReloadList();
        }
        else
        {
            Snackbar.Add("Failed to delete the server.", Severity.Error);
        }
    }

    private async Task ReloadList()
    {
        _servers = await ServerClient.GetServersList();
        StateHasChanged();
    }
}
