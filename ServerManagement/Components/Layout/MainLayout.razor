@using ServerManagement.State
@inherits LayoutComponentBase
@inject AppState AppState

@* Required *@
<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" @ref="_mudThemeProvider" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())"/>
        <MudText Typo="Typo.h5" Class="ml-3">Server Management System</MudText>
        <MudSpacer />

        <MudIconButton Icon="@_themeIcon" Color="Color.Inherit" aria-label="toggle dark mode"
                       @onclick="ToggleDarkMode"/>

        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End">
            <MudMenuItem Label="User Profile" Icon="@Icons.Material.Filled.Person"/>
            <MudMenuItem Label="Logout" Icon="@Icons.Material.Filled.Logout"/>
        </MudMenu>

    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
@code {
    bool _drawerOpen = true;
    private bool _isDarkMode;
    string _themeIcon = Icons.Material.Filled.DarkMode;
    private MudThemeProvider? _mudThemeProvider;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _mudThemeProvider != null)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
            _themeIcon = _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;
            await _mudThemeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChanged);
            StateHasChanged();
        }
    }

    private Task OnSystemDarkModeChanged(bool arg)
    {
        if (arg)
        {
            // enable dark mode
            _themeIcon = Icons.Material.Filled.LightMode;
            _isDarkMode = true;
        }
        else
        {
            _themeIcon = Icons.Material.Filled.DarkMode;
            _isDarkMode = false;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    void ToggleDarkMode()
    {
        var userPreferences = GetUserPreferencesFromAppState();
        if (_themeIcon == Icons.Material.Filled.DarkMode)
        {
            // currently light mode, set to dark mode
            _themeIcon = Icons.Material.Filled.LightMode;
            _isDarkMode = true;
            StateHasChanged();
            userPreferences.IsDarkModeEnabled = _isDarkMode;
            AppState.SetUserPreferences(userPreferences);
            return;
        }

        // currently dark mode, set to light mode
        _themeIcon = Icons.Material.Filled.DarkMode;
        _isDarkMode = false;
        StateHasChanged();
        userPreferences.IsDarkModeEnabled = _isDarkMode;
        AppState.SetUserPreferences(userPreferences);
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
        var userPreferences = GetUserPreferencesFromAppState();

        userPreferences.IsDrawerOpen = _drawerOpen;
        AppState.SetUserPreferences(userPreferences);
    }

    private UserPreferences GetUserPreferencesFromAppState()
    {
        var userPreferences = AppState.GetUserPreferences();

        return userPreferences ?? new UserPreferences();
    }

}
