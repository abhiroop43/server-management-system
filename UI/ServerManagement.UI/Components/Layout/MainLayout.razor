@using Microsoft.AspNetCore.Components.Authorization
@using ServerManagement.UI.Providers
@using ServerManagement.UI.State
@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject JwtAuthenticationStateProvider AuthenticationStateProvider

@* Required *@
<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" @ref="_mudThemeProvider"/>
<MudPopoverProvider/>

@* Needed for dialogs *@
<MudDialogProvider/>

@* Needed for snackbars *@
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@(e => DrawerToggle())"/>
            </Authorized>
        </AuthorizeView>

        <MudImage @onclick="RedirectToRoot" Style="cursor: pointer" Src="images/logo.png" Width="50" Height="50"
                  Class="pb-1 pt-0"></MudImage>
        <MudText @onclick="RedirectToRoot" Style="cursor: pointer" Typo="Typo.h5" Class="ml-3">
            Server Management System
        </MudText>

        <MudSpacer/>

        <MudIconButton Icon="@_themeIcon" Color="Color.Inherit" aria-label="toggle dark mode"
                       @onclick="ToggleDarkMode"/>

        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End">
                    <MudMenuItem Label="User Profile" Icon="@Icons.Material.Filled.Person"/>
                    <MudMenuItem Label="Logout" Icon="@Icons.Material.Filled.Logout" @onclick="LogoutUserAsync"/>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Class="mx-2"
                           Variant="Variant.Filled"
                           EndIcon="@Icons.Material.Filled.Login"
                           Color="Color.Error"
                           @onclick="LoginButtonClicked">
                    Login
                </MudButton>
                <MudButton Class="mx-2"
                           Variant="Variant.Filled"
                           EndIcon="@Icons.Material.Filled.EditNote"
                           Color="Color.Tertiary"
                           @onclick="RegisterButtonClicked">
                    Register
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu/>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent>
        <MudContainer Class="mt-6" Fixed="true">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    private bool _isDarkMode;
    string _themeIcon = Icons.Material.Filled.DarkMode;
    private MudThemeProvider? _mudThemeProvider;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _mudThemeProvider != null)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
            _themeIcon = _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;
            await _mudThemeProvider.WatchSystemDarkModeAsync(OnSystemDarkModeChanged);
            StateHasChanged();
        }
    }

    private Task OnSystemDarkModeChanged(bool arg)
    {
        if (arg)
        {
            // enable dark mode
            _themeIcon = Icons.Material.Filled.LightMode;
            _isDarkMode = true;
        }
        else
        {
            _themeIcon = Icons.Material.Filled.DarkMode;
            _isDarkMode = false;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    void ToggleDarkMode()
    {
        var userPreferences = GetUserPreferencesFromAppState();
        if (_themeIcon == Icons.Material.Filled.DarkMode)
        {
            // currently light mode, set to dark mode
            _themeIcon = Icons.Material.Filled.LightMode;
            _isDarkMode = true;
            StateHasChanged();
            userPreferences.IsDarkModeEnabled = _isDarkMode;
            AppState.SetUserPreferences(userPreferences);
            return;
        }

        // currently dark mode, set to light mode
        _themeIcon = Icons.Material.Filled.DarkMode;
        _isDarkMode = false;
        StateHasChanged();
        userPreferences.IsDarkModeEnabled = _isDarkMode;
        AppState.SetUserPreferences(userPreferences);
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
        var userPreferences = GetUserPreferencesFromAppState();

        userPreferences.IsDrawerOpen = _drawerOpen;
        AppState.SetUserPreferences(userPreferences);
    }

    private UserPreferences GetUserPreferencesFromAppState()
    {
        var userPreferences = AppState.GetUserPreferences();

        return userPreferences ?? new UserPreferences();
    }

    private void LoginButtonClicked()
    {
        NavigationManager.NavigateTo("/login");
    }

    private void RegisterButtonClicked()
    {
        NavigationManager.NavigateTo("/register");
    }

    private void RedirectToRoot()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task LogoutUserAsync()
    {
        Console.WriteLine("Logging out the user");
        await AuthenticationStateProvider.NotifyUserLogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

}
