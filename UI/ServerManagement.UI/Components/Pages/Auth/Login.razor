@page "/login"
@using ServerManagement.UI.Providers

@inject AuthClient AuthClient
@inject ISnackbar Snackbar
@inject JwtAuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<MudText Typo="Typo.h3">Let's get you signed in</MudText>

<EditForm Model="@_dataModel" OnValidSubmit="OnValidSubmitAsync">
    <DataAnnotationsValidator/>
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-5">
        <MudCard Outlined="true">
            <MudCardContent>
                <MudTextField Label="Email" HelperText="john.doe@example.com"
                              @bind-Value="_dataModel.Email"
                              For="@(() => _dataModel.Email)"/>

                <MudTextField Label="Password" InputType="InputType.Password"
                              HelperText="************"
                              @bind-Value="_dataModel.Password"
                              For="@(() => _dataModel.Password)"
                />

            </MudCardContent>

            <MudCardActions>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="mr-2">Login
                </MudButton>
                <MudButton ButtonType="ButtonType.Reset"
                           Variant="Variant.Outlined"
                           Color="Color.Default" Class="ml-2"
                           @onclick="ResetForm">
                    Reset
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudContainer>
</EditForm>

@code {
    UserLogin _dataModel = new();

    private async Task OnValidSubmitAsync()
    {
        var response = await AuthClient.Login(_dataModel);

        if (response == null)
        {
            Snackbar.Add("Something went wrong. Login Failed.", Severity.Error);
            return;
        }

        if (!response.Success || string.IsNullOrWhiteSpace(response.Token))
        {
            Snackbar.Add($"Login Failed. The email and/or the password is incorrect", Severity.Error);
            return;
        }

        await AuthenticationStateProvider.NotifyAuthenticationAsync(response.Token);
        NavigationManager.NavigateTo($"/servers");
    }

    private void ResetForm()
    {
        _dataModel = new UserLogin();
        StateHasChanged();
    }

}